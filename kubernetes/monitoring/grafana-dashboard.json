{
  "__comment__": "Grafana 대시보드 설정. ConfigMap으로 Grafana에 자동 로드된다. 직접 수정하지 말고, Grafana UI에서 수정 후 JSON을 Export해서 이 파일을 갱신한다.",
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Pod CPU 사용률",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"dev|prod\", container!=\"\"}[5m])) by (pod)",
          "legendFormat": "{{ pod }}"
        }
      ]
    },
    {
      "title": "Pod 메모리 사용량",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"dev|prod\", container!=\"\"}) by (pod)",
          "legendFormat": "{{ pod }}"
        }
      ]
    },
    {
      "title": "Pod 재시작 횟수",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=~\"dev|prod\"}) by (pod)"
        }
      ]
    },
    {
      "title": "Running Pods",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{phase=\"Running\", namespace=~\"dev|prod\"})"
        }
      ]
    },
    {
      "title": "HPA 현재 Replicas",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=~\"dev|prod\"}"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["devsecops", "dashboard"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "DevSecOps Dashboard",
